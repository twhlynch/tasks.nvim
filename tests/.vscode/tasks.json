// comments should be removed
{
	"version": "2.0.0",
	"tasks": [
		{
			// should resolve: folder, input, ~
			"label": "expansion",
			"type": "shell",
			"command": "echo",
			"args": ["${workspaceFolder}", "${input:inputId}", "$HOME"],
			"options": {
				"env": {
					"CUSTOM_VAR": "value"
				}
			}
		},
		{
			// "a" 'b' c d
			"label": "quotes",
			"type": "shell",
			"command": "echo",
			"args": ["\"a\"", "'b'", "c d"]
		},
		{
			"label": "bad exit",
			"type": "shell",
			"command": "exit 1",
		},
		{
			"label": "sleep",
			"type": "shell",
			"command": "sleep 5 && echo 'sleep'",
		},
		{
			// hello world
			"label": "hello world",
			"type": "shell",
			"command": "echo \"hello world\""
		},
		{
			// invalid since args exists and command has a space
			"label": "broken",
			"type": "shell",
			"command": "echo arg",
			"args": ["arg",], // trailing commas are removed
		},
		{
			// prelaunch
			"label": "prelaunch task",
			"type": "shell",
			"command": "echo",
			"args": ["prelaunch"]
		},
		{
			// default build task for ${defaultBuildTask}
			"label": "default build",
			"type": "shell",
			"command": "echo",
			"args": ["building"],
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			// npm task
			"label": "npm task",
			"type": "npm",
			"script": "simple"
		},
		{
			// process task
			"label": "process task",
			"type": "process",
			"command": "echo",
			"args": ["process"]
		},
		{
			// task with cwd
			"label": "custom cwd",
			"type": "shell",
			"command": "pwd",
			"options": {
				"cwd": "/tmp"
			}
		},
		{
			// no label
			"type": "shell",
			"command": "skipme"
		},
		{
			// all variables
			"label": "all variables",
			"type": "shell",
			"command": "echo",
			"args": [
				"\nuserHome:                 ${userHome}",
				"\nworkspaceFolder:          ${workspaceFolder}",
				"\nworkspaceFolderBasename:  ${workspaceFolderBasename}",
				"\nfile:                     ${file}",
				"\nfileWorkspaceFolder:      ${fileWorkspaceFolder}",
				"\nrelativeFile:             ${relativeFile}",
				"\nrelativeFileDirname:      ${relativeFileDirname}",
				"\nfileBasename:             ${fileBasename}",
				"\nfileBasenameNoExtension:  ${fileBasenameNoExtension}",
				"\nfileExtname:              ${fileExtname}",
				"\nfileDirname:              ${fileDirname}",
				"\nfileDirnameBasename:      ${fileDirnameBasename}",
				"\ncwd:                      ${cwd}",
				"\nlineNumber:               ${lineNumber}",
				"\ncolumnNumber:             ${columnNumber}",
				"\nselectedText:             ${selectedText}",
				"\nexecPath:                 ${execPath}",
				"\npathSeparator:            ${pathSeparator}",
				"\n/:                        ${/}",
				"\nworkspaceRoot:            ${workspaceRoot}",
				"\nenv:HOME:                 ${env:HOME}",
				"\nHOME:                     $HOME",
			]
		},
		{
			// prompt
			"label": "input promptString",
			"type": "shell",
			"command": "echo",
			"args": ["${input:inputId}"]
		},
		{
			// pick
			"label": "input pickString",
			"type": "shell",
			"command": "echo",
			"args": ["${input:pickId}"]
		},
		{
			// pick labels
			"label": "input pickLabel",
			"type": "shell",
			"command": "echo",
			"args": ["${input:pickLabelId}"]
		},
		{
			// password
			"label": "input password",
			"type": "shell",
			"command": "echo",
			"args": ["${input:passwordId}"]
		}
	],
	"inputs": [
		{
			"id": "inputId",
			"type": "promptString",
			"description": "Enter a value",
			"default": "default"
		},
		{
			"id": "passwordId",
			"type": "promptString",
			"description": "Enter password",
			"password": true,
			"default": "hunter2"
		},
		{
			"id": "pickId",
			"type": "pickString",
			"description": "Pick an option",
			"options": ["alpha", "beta", "gamma"],
			"default": "alpha"
		},
		{
			"id": "pickLabelId",
			"type": "pickString",
			"description": "Pick a language",
			"options": [
				{ "label": "Lua", "value": "lua" },
				{ "label": "Python", "value": "python" },
				{ "label": "Rust", "value": "rust" }
			],
			"default": "lua"
		}
	]
}
